# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=prr
POSTGRES_PASSWORD=prr_dev_password
POSTGRES_DB=public_risk_radar
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgres://prr:prr_dev_password@localhost:5432/public_risk_radar
# Redis backs the upstream HTTP cache (shared + survives restarts).
# If unreachable, the app falls back to a per-process in-memory cache.
REDIS_URL=redis://localhost:6379

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# Comma-separated origins allowed by CORS (the Vite dev server)
CORS_ORIGIN=http://localhost:5173

# ── External API keys ───────────────────────────────────────────────────────
# AirNow requires a free key: https://docs.airnowapi.org/account/request/
AIRNOW_API_KEY=
# NWS requires no key but asks for a descriptive User-Agent with contact info.
NWS_USER_AGENT=public-risk-radar (codydevlearning@gmail.com)

# ── Demo geography (Phoenix / Maricopa County) ──────────────────────────────
# Used to bound the first demo. Maricopa County FIPS = 04013 (state 04, county 013)
DEMO_STATE_FIPS=04
DEMO_COUNTY_FIPS=013

# ── Alerts (background worker) ──────────────────────────────────────────────
# Off by default. When true, the server evaluates active alert_subscriptions on
# an interval and delivers via each subscription's Discord webhook (delivery_target).
ALERTS_ENABLED=false
ALERTS_INTERVAL_MS=300000   # 5 minutes
